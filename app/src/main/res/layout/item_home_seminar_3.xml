<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardSeminar3"
    android:layout_width="match_parent"
    android:layout_height="165dp"
    android:layout_marginTop="18dp"
    android:background="@drawable/bg_meow_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <FrameLayout
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:background="@drawable/bg_image_placeholder"
        android:clipToOutline="true"
        android:padding="0dp">

        <ImageView
            android:id="@+id/imgSeminar3"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Seminar Image"
            android:scaleType="centerCrop"
            android:src="@drawable/cat_human" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSeminarTitle3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:text="Cats and Human Civilization"
            android:textColor="@color/meow_black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSeminarDesc3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:maxLines="3"
            android:text="Learn how cats became part of human life and culture."
            android:textColor="@color/meow_black"
            android:textSize="11.5sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="39dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSeminarDate3"
                android:layout_width="92dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_meow_button_outline"
                android:gravity="center"
                android:text="Sun, 11th Jan"
                android:textColor="@color/meow_black"
                android:textSize="9.5sp" />

            <Button
                android:id="@+id/btnJoin3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="7dp"
                android:layout_weight="1"
                android:background="@drawable/bg_meow_button_black"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="Join Seminar"
                android:textAllCaps="false"
                android:textColor="@color/meow_white"
                android:textSize="9.5sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>