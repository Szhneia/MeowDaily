<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="165dp"
    android:layout_marginTop="18dp"
    android:background="@drawable/bg_meow_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <FrameLayout
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:background="@drawable/bg_image_placeholder"
        android:clipToOutline="true"
        android:padding="0dp">

        <ImageView
            android:id="@+id/imgSeminar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Seminar Image"
            android:scaleType="centerCrop"
            android:src="@drawable/cat_origin" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="18dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The Origin of Cats"
            android:textColor="@color/meow_black"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Learn how cats first appeared and became part of human history."
            android:textColor="@color/meow_black"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="88dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_meow_button_outline"
                android:gravity="center"
                android:text="Mon, 18th May"
                android:textColor="@color/meow_black"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnJoin1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_meow_button_black"
                android:text="Join Seminar"
                android:textAllCaps="false"
                android:textColor="@color/meow_white"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>