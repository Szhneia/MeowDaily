<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F3F3">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="130dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="155dp">

            <!-- HERO CARD -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="390dp"
                android:background="@drawable/bg_meow_card"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingStart="22dp"
                android:paddingTop="22dp"
                android:paddingEnd="22dp"
                android:paddingBottom="22dp">

                <!-- Judul kiri atas -->
                <TextView
                    android:id="@+id/tvHomeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MeowDaily"
                    android:textColor="#000000"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <!-- Icon profile kanan atas -->
                <FrameLayout
                    android:id="@+id/btnProfileTop"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_gravity="end|top"
                    android:background="@drawable/bg_meow_profile_circle"
                    android:clipToOutline="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="2dp">

                    <ImageView
                        android:id="@+id/imgProfileTop"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:adjustViewBounds="false"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_nav_profile" />

                </FrameLayout>

                <!-- Welcome -->
                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="225dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="105dp"
                    android:text="Welcome Meowie, [Name]!"
                    android:textColor="#000000"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <!-- Deskripsi -->
                <TextView
                    android:id="@+id/tvHeroDesc"
                    android:layout_width="215dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="175dp"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="5"
                    android:text="Discover various interesting seminars about cat history, from the origins of cats to their role in human life with MeowDaily!"
                    android:textColor="#000000"
                    android:textSize="13sp" />

                <!-- Gambar kucing kanan -->
                <ImageView
                    android:id="@+id/imgHeroCat"
                    android:layout_width="200dp"
                    android:layout_height="280dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginTop="-5dp"
                    android:layout_marginEnd="-20dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Cat Image"
                    android:scaleType="fitEnd"
                    android:src="@drawable/cuking1" />

                <!-- Search bar bawah -->
                <LinearLayout
                    android:id="@+id/layoutSearch"
                    android:layout_width="270dp"
                    android:layout_height="46dp"
                    android:layout_gravity="start|bottom"
                    android:layout_marginBottom="28dp"
                    android:background="@drawable/bg_meow_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Search"
                        android:src="@android:drawable/ic_menu_search"
                        android:tint="#000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Search for cat seminars or topics.."
                        android:textColor="#9C9C9C"
                        android:textSize="12sp" />

                </LinearLayout>

            </FrameLayout>

            <!-- SECTION TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="14dp"
                android:text="Discover Seminars"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- CARD SEMINAR HOME, SAME AS SEMINAR LIST -->
            <include
                android:id="@+id/cardSeminar1"
                layout="@layout/item_home_seminar_1" />

            <include
                android:id="@+id/cardSeminar2"
                layout="@layout/item_home_seminar_2" />

            <include
                android:id="@+id/cardSeminar3"
                layout="@layout/item_home_seminar_3" />

        </LinearLayout>

    </ScrollView>

    <include layout="@layout/view_floating_nav" />

</FrameLayout>